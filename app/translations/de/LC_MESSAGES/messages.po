#: templates/includes/de/help.html:14 templates/includes/en/help.html:14
#, python-format
msgid ""
"You can edit your order within the first 3 minutes of ordering "
"%(open)shere%(close)s. It can take up to 3 days to reprocess the payment."
msgstr "Sie können Ihre Bestellung %(open)shier%(close)s innerhalb der ersten"
"3 Minuten nach der Bestellung bearbeiten. Die erneute Bearbeitung der Zahlung"
"kann bis zu 3 Tage dauern."

#: templates/includes/de/help.html:20 templates/includes/en/help.html:20
msgid "My order did not arrive"
msgstr "Meine Bestellung ist nicht angekommen"

#: templates/includes/de/help.html:24 templates/includes/en/help.html:24
#, python-format
msgid ""
"Use our %(open)sLive Chat%(close)s to discuss the matter with our "
"support. An investigation may take a few days."
msgstr "Nutzen Sie unseren %(open)sLive-Chat%(close)s, um die Angelegenheit"
"mit unserem Support zu besprechen. Die Untersuchung kann einige Tage dauern."

#: templates/includes/de/help.html:30 templates/includes/en/help.html:30
msgid "Part of my order is missing"
msgstr "Ein Teil meiner Bestellung fehlt"

#: templates/includes/de/help.html:34 templates/includes/en/help.html:34
#, python-format
msgid ""
"Please %(open)supload%(close)s photo evidence of your receipt. You will "
"be refunded in two days."
msgstr "Bitte %(open)sladen Sie%(close)s ein Foto Ihrer Quittung hoch. Die"
"Rückerstattung erfolgt innerhalb von 2 Tagen."

